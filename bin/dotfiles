#!/usr/bin/env bash

# Logging stuff.
function e_header()   { echo -e "\n\033[1m$@\033[0m"; }
function e_success()  { echo -e " \033[1;32m✔\033[0m  $@"; }
function e_error()    { echo -e " \033[1;31m✖\033[0m  $@"; }
function e_arrow()    { echo -e " \033[1;34m➜\033[0m  $@"; }

DOTFILES=~/.dotfiles
if [[ ! -d $DOTFILES ]]; then
	git clone https://github.com/yezooz/dotfiles.git $DOTFILES
fi

# OS detection
function is_macos() {
  [[ "$OSTYPE" =~ ^darwin ]] || return 1
}
function is_linux() {
  [[ "$OSTYPE" =~ ^linux ]] || return 1
}
function is_ubuntu() {
  [[ "$(cat /etc/issue 2> /dev/null)" =~ Ubuntu ]] || return 1
}
function is_ubuntu_desktop() {
  dpkg -l ubuntu-desktop >/dev/null 2>&1 || return 1
}
function get_os() {
  for os in macos ubuntu ubuntu_desktop; do
    is_$os; [[ $? == ${1:-0} ]] && echo $os
  done
}

function is_git_repo() {
  [[ -d .git ]] || return 1
}

if [[ -z $DOTFILES ]]; then
  e_error "$$DOTFILES not set. Please set it to the root of your dotfiles."
  exit 1
fi

if [[ ! -d $DOTFILES ]]; then
  e_header "Fetching dotfiles from github..."
	git clone https://github.com/yezooz/dotfiles.git $DOTFILES
  e_success "Done."
fi

deps=(path.zsh exports.zsh aliases.zsh functions.zsh autocomplete.zsh bindkeys.zsh)
is_macos && deps+=(macos.zsh)
is_linux && deps+=(linux.zsh)

if [[ -n $DEBUG ]]; then
  e_header "Sourcing zsh files from dotfiles..."
  # Start timer (milliseconds)
  local start_time=$(($(date +%s%N)/1000000))
fi

# Load the shell dotfiles, and then some:
for file in "${deps[@]}"; do
  f="$DOTFILES/zsh/deps/$file"

  if [[ -n $DEBUG ]]; then
    local file_start=$(($(date +%s%N)/1000000))
  fi

	[[ -f $f ]] && source $f || e_error "File not found: $f"

  if [[ -n $DEBUG ]]; then
    local file_end=$(($(date +%s%N)/1000000))
    local file_duration=$((file_end - file_start))
    e_arrow "$file done (${file_duration}ms)"
  fi
done;

if [[ -n $DEBUG ]]; then
  local end_time=$(($(date +%s%N)/1000000))
  local total_duration=$((end_time - start_time))
  e_success "All files sourced in ${total_duration}ms"
fi

fpath+="$DOTFILES/zsh/zfunc"
fpath+="$BREW_PREFIX/share/zsh/site-functions"

if [[ -n $DEBUG ]]; then
  e_header "Summary"
  e_success "\$PATH=$PATH"
  e_success "\$FPATH=$FPATH"
fi

# If this file was being sourced, exit now.
[[ "$1" == "source" ]] && return

# Ensure that we can actually, like, compile anything.
if ! command -v gcc &>/dev/null && is_macos; then
  e_error "XCode or the Command Line Tools for XCode must be installed first."
  exit 1
fi

# If Git is not installed, install it (Ubuntu only, since Git comes standard
# with recent XCode or CLT)
if ! command -v git &>/dev/null && is_ubuntu; then
  e_header "Installing Git"
  sudo apt-get -qq install git-core
fi

# If Git isn't installed by now, something exploded. We gots to quit!
if ! command -v git &>/dev/null; then
  e_error "Git should be installed. It isn't. Aborting."
  exit 1
fi

if is_macos; then
  e_header "MacOS installation: Starting"
  source $DOTFILES/init/macos.sh
  e_success "MacOS installation: Complete"
fi

if is_ubuntu; then
  e_header "Ubuntu installation: Starting"
  source $DOTFILES/init/ubuntu.sh
  e_success "Ubuntu installation: Complete"
fi

# Add binaries into the path
# [[ -d $DOTFILES/bin ]] && export PATH=$DOTFILES/bin:$PATH

# Create caches dir and init subdir, if they don't already exist.
mkdir -p "$DOTFILES/caches/init"

# Load config to check for optional installations
CONFIG_FILE="${DOTFILES}/.install-config"
if [[ -f "$CONFIG_FILE" ]]; then
  source "$CONFIG_FILE"
fi

# Optional: Install additional Homebrew packages
if [[ "${INSTALL_BREW_PACKAGES}" == "yes" ]] && [[ -f "$DOTFILES/brew.sh" ]]; then
  e_header "Installing additional Homebrew packages"
  /bin/bash "$DOTFILES/brew.sh"
  e_success "Homebrew packages installed"
fi

# Optional: Install development tools
if [[ "${INSTALL_DEV_TOOLS}" == "yes" ]] && [[ -f "$DOTFILES/init/dev_tools.sh" ]]; then
  e_header "Installing development tools"
  /bin/bash "$DOTFILES/init/dev_tools.sh"
  e_success "Development tools installed"
fi

# Optional: Install desktop applications
if [[ "${INSTALL_DESKTOP_APPS}" == "yes" ]] && [[ -f "$DOTFILES/init/desktop_tools.sh" ]]; then
  e_header "Installing desktop applications"
  /bin/bash "$DOTFILES/init/desktop_tools.sh"
  e_success "Desktop applications installed"
fi

# Optional: Generate SSH key
if [[ "${GENERATE_SSH}" == "yes" ]] && [[ -f "$DOTFILES/ssh.sh" ]]; then
  if [[ ! -f "$HOME/.ssh/id_ed25519" ]]; then
    e_header "Generating SSH key"
    if [[ -n "${USER_EMAIL}" ]]; then
      /bin/bash "$DOTFILES/ssh.sh" "${USER_EMAIL}"
      e_success "SSH key generated"
      e_arrow "Public key location: $HOME/.ssh/id_ed25519.pub"
    else
      e_error "USER_EMAIL not set, skipping SSH key generation"
    fi
  else
    e_arrow "SSH key already exists, skipping generation"
  fi
fi

# Optional: Apply macOS defaults
if [[ "${APPLY_MACOS_DEFAULTS}" == "yes" ]] && is_macos && [[ -f "$DOTFILES/mac/macos_defaults.sh" ]]; then
  e_header "Applying macOS system defaults"
  /bin/bash "$DOTFILES/mac/macos_defaults.sh"
  e_success "macOS defaults applied"
fi

# All done!
e_header "All done!"